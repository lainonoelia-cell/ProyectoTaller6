<script src="https://unpkg.com/html5-qrcode"></script>

@{
    ViewData["Title"] = "Escaneo Codigo";
}

<link rel="stylesheet" href="~/css/escaneo.css" />

<h1 class="titulo">ESCANEO CÓDIGO PRODUCTO</h1>

<div class="contenedor-escaneo">

    <p class="mensaje">
        Por favor, apunte la cámara al código de la prenda
    </p>

    <!-- 📷 CAMARA -->
    <div class="camara-grande">
        <img src="~/images/camara2.png" onclick="iniciarEscaneo()" style="cursor:pointer;" />
    </div>

    <div id="reader" style="width:300px; display:none;"></div>

    <!-- FLASH EFFECTS -->
    <div id="flashOk" class="flash ok"></div>
    <div id="flashError" class="flash error"></div>

    <!-- RESULTADOS -->
    <p id="ok1" class="resultado1 ok1" style="display:none;">
        Producto encontrado ✅
    </p>

    <p id="error1" class="resultado1 error1" style="display:none;">
        Producto no encontrado ❌
    </p>

    <!-- MANUAL -->
    <div class="manual">
        <input type="text" id="codigoInput" placeholder="Ingresar código manual" />
        <button onclick="buscarCodigo()">Buscar 🔎</button>
    </div>

</div>

<!-- 📷 SCANNER + LOGICA -->
<script>

let sonidoOk = new Audio("/sounds/success.mp3");
let sonidoError = new Audio("/sounds/error.mp3");

let scanner;


// 🔊 VOZ
function hablar(texto) {

    const mensaje = new SpeechSynthesisUtterance(texto);

    mensaje.lang = "es-AR";
    mensaje.rate = 1;
    mensaje.pitch = 1;

    speechSynthesis.speak(mensaje);
}


// 📷 INICIAR ESCANEO
function iniciarEscaneo() {

    document.getElementById("reader").style.display = "block";

    scanner = new Html5Qrcode("reader");

    Html5Qrcode.getCameras().then(cameras => {

        let cameraId = cameras[0].id;

        scanner.start(
            cameraId,
            { fps: 10, qrbox: 250 },
            (codigo) => {

                codigo = codigo.trim();

                document.getElementById("codigoInput").value = codigo;

                validarCodigo(codigo);

                scanner.stop();
            }
        );

    });
}


// 🟢 VALIDAR CODIGO
function validarCodigo(codigo) {

    fetch('/Home/BuscarPorCodigo?codigo=' + codigo)
        .then(res => res.json())
        .then(data => {

            if (!data.encontrado) {

                feedbackError();

                setTimeout(() => {
                    window.location.href = "/Home/Inventario1?error=1";
                }, 800);

                return;
            }

            feedbackOk();

            setTimeout(() => {
                window.location.href =
                "/Home/Inventario2?codigo=" + codigo;
            }, 3000);
        });
}


// 🟢 BUSQUEDA MANUAL
function buscarCodigo() {

    let codigo =
        document.getElementById("codigoInput").value.trim();

    if (!codigo) return;

    validarCodigo(codigo);
}


// ✅ OK
function feedbackOk() {

    document.getElementById("ok1").style.display = "block";
    document.getElementById("error1").style.display = "none";

    const flash = document.getElementById("flashOk");

    flash.style.display = "flex";

    try {

        sonidoOk.currentTime = 0;
        sonidoOk.play();

        // Espera a que termine el sonido
        setTimeout(() => {
            hablar("Producto encontrado");
        }, 600);

    }
    catch (e) {}

    setTimeout(() => {
        flash.style.display = "none";
    }, 1000);
}


// ❌ ERROR
function feedbackError() {

    document.getElementById("error1").style.display = "block";
    document.getElementById("ok1").style.display = "none";

    const flash = document.getElementById("flashError");

    flash.style.display = "flex";

    if (navigator.vibrate) {
        navigator.vibrate(200);
    }

    try {

        sonidoError.currentTime = 0;
        sonidoError.play();

        // ⏳ ESPERA PARA LA VOZ
        setTimeout(() => {
            hablar("Producto no encontrado");
        }, 700);

    }
    catch (e) {}

    setTimeout(() => {
        flash.style.display = "none";
    }, 900);
}

</script>



<!-- 🔥 LOGOS -->
<div class="logo-centro">
    <img src="~/images/logoCDNsis.png" />
</div>

<div class="logo-derecha">
    <img src="~/images/logoMM.png" />
</div>

<!-- 🔙 VOLVER -->
<a href="/Home/Inventario1" class="btn-volver">⬅</a>