@model List<ProyectoTaller6.Models.Producto>

@{
    ViewData["Title"] = "Categoria";
}

<link rel="stylesheet" href="~/css/categoria.css" />

<!-- BOTON VOLVER -->
<a href="/Home/Inventario1" class="btn-volver">⬅</a>

<h1 class="titulo">@ViewBag.Tipo</h1>

<button onclick="mostrarFormulario()" class="btn-nuevo">➕ Nuevo Producto</button>

<div id="formNuevo" style="display:none; margin-top:20px;">

    <input type="text" id="nombre" placeholder="Nombre" />
    <input type="number" id="stock" placeholder="Stock" />
    <input type="number" id="precio" placeholder="Precio" />
    <input type="text" id="imagen" placeholder="Nombre imagen (ej: remera.png)" />

    <select id="tipo">
    <option value="General">General</option>

    @foreach (var s in ViewBag.Subcategorias)
    {
        <option value="@s.Nombre">@s.Nombre</option>
    }
</select>

    <button onclick="crearProducto()">Guardar ✅</button>
</div>

<script>
function mostrarFormulario() {
    document.getElementById("formNuevo").style.display = "block";
}
</script>

<script>
function crearProducto() {

    let nombre = document.getElementById("nombre").value;
    let stock = document.getElementById("stock").value;
    let precio = document.getElementById("precio").value;
    let imagen = document.getElementById("imagen").value;
    let tipo = document.getElementById("tipo").value;

    fetch('/Home/CrearProducto', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
            Nombre: nombre,
            Stock: parseInt(stock),
            Precio: parseInt(precio),
            Imagen: imagen,
            Categoria: '@ViewBag.Tipo',
            Tipo: tipo
        })
    })
    .then(res => res.json())
    .then(data => {
        if (data.ok) {
            alert("Producto creado ✅");
            location.reload();
        }
    });
}
</script>

<!-- FILTROS DINAMICOS -->
<div class="subcategorias">

<button onclick="filtrar('Todos')">Todos</button>

@foreach (var s in ViewBag.Subcategorias)
{
    <button onclick="filtrar('@s.Nombre')">@s.Nombre</button>
}

</div>

<input type="text" id="nuevaSub" placeholder="Nueva subcategoría" />

<button onclick="crearSub()">Agregar Subcategoría</button>

<script>
function crearSub() {

    let nombre = document.getElementById("nuevaSub").value;

    fetch('/Home/CrearSubcategoria', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
            Nombre: nombre,
            Categoria: '@ViewBag.Tipo'
        })
    })
    .then(res => res.json())
    .then(data => {
        if (data.ok) {
            alert("Subcategoría creada ✅");
            location.reload();
        }
    });
}
</script>

<!-- PRODUCTOS -->
<div class="contenedor">

    @foreach (var p in Model)
    {
        <div class="producto" data-tipo="@p.Tipo">
            <img src="~/images/@p.Imagen" />

            <p>@p.Nombre</p>
            <p style="color:@(p.Stock == 0 ? "red" : "black")">Stock: @p.Stock</p>
            <p>Precio: $@p.Precio</p>

            <div class="acciones">
                <a href="/Home/EditarProducto?id=@p.Id">
                    <button>Editar</button>
                </a>
                <button onclick="eliminarProducto(@p.Id)">Eliminar</button>
                <button onclick="agregarCodigo(@p.Id)">Agregar</button>
            </div>
        </div>
    }

</div>

<script>
function filtrar(tipo) {
    let productos = document.querySelectorAll(".producto");

    productos.forEach(p => {
        if (tipo === "Todos" || p.dataset.tipo === tipo) {
            p.style.display = "block";
        } else {
            p.style.display = "none";
        }
    });
}
</script>

<!-- CAMARA -->
<div class="camara">
    <a href="/Home/EscaneoCodigo">
        <img src="~/images/camara2.png" />
    </a> 
</div>

<script>
function agregarCodigo(idProducto) {

    fetch('/Home/GenerarCodigoProducto?id=' + idProducto)
    .then(res => res.json())
    .then(data => {

        if (data.ok) {
            alert("Código generado: " + data.codigo + " ✅");
        } else {
            alert("Error al generar código ❌");
        }

    });
}
</script>


<script>
function eliminarProducto(id) {

    if (!confirm("¿Seguro que querés eliminar este producto?")) return;

    fetch('/Home/EliminarProducto?id=' + id, {
        method: 'POST'
    })
    .then(res => res.json())
    .then(data => {
        if (data.ok) {
            alert("Producto eliminado ✅");
            location.reload();
        }
    });
}
</script>


<!-- LOGOS -->
<div class="logo-centro">
    <img src="~/images/logoCDNsis.png" />
</div>

<div class="logo-derecha">
    <img src="~/images/logoMM.png" />
</div>