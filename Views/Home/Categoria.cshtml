@model List<ProyectoTaller6.Models.Producto>

@{
    ViewData["Title"] = "Categoria";
}

<link rel="stylesheet" href="~/css/categoria.css" />

<!-- BOTON VOLVER -->
<a href="/Home/Inventario1" class="btn-volver">⬅</a>

<h1 class="titulo">@ViewBag.Tipo</h1>

<!-- FILTROS DINAMICOS -->
@if (ViewBag.Tipo == "Remeras")
{
    <div class="subcategorias">
        <button onclick="filtrar('Todos')">Todos</button>
        <button onclick="filtrar('RemerasLisas')">Remeras lisas</button>
        <button onclick="filtrar('RemerasEstampadas')">Remeras estampadas</button>
    </div>
}

@if (ViewBag.Tipo == "Abrigos")
{
    <div class="subcategorias">
        <button onclick="filtrar('Todos')">Todos</button>
        <button onclick="filtrar('Camperas')">Camperas</button>
        <button onclick="filtrar('Chalecos')">Chalecos</button>
        <button onclick="filtrar('Buzos')">Buzos</button>
        <button onclick="filtrar('Sweaters')">Sweaters</button>
    </div>
}

@if (ViewBag.Tipo == "Pantalones")
{
    <div class="subcategorias">
        <button onclick="filtrar('Todos')">Todos</button>
        <button onclick="filtrar('Jeans')">Jeans</button>
        <button onclick="filtrar('Deportivo')">Deportivo</button>
        <button onclick="filtrar('Cargo')">Cargo</button>
        <button onclick="filtrar('Joggins')">Joggins</button>
        <button onclick="filtrar('Gabardina')">Gabardina</button>
    </div>
}


@if (ViewBag.Tipo == "Cortos")
{
    <div class="subcategorias">
        <button onclick="filtrar('Todos')">Todos</button>
        <button onclick="filtrar('Bermudas')">Bermudas</button>
        <button onclick="filtrar('Shorts')">Shorts</button>
    </div>
}


@if (ViewBag.Tipo == "Accesorios")
{
    <div class="subcategorias">
        <button onclick="filtrar('Todos')">Todos</button>
        <button onclick="filtrar('Gorros')">Gorros</button>
        <button onclick="filtrar('Riñoneras')">Riñoneras</button>
    </div>
}

<!-- PRODUCTOS -->
<div class="contenedor">

    @foreach (var p in Model)
    {
        <div class="producto" data-tipo="@p.Tipo">
            <img src="~/images/@p.Imagen" />

            <p>@p.Nombre</p>
            <p>Stock: @p.Stock</p>
            <p>Precio: $@p.Precio</p>

            <div class="acciones">
                <a href="/Home/EditarProducto?id=@p.Id">
                    <button>Editar</button>
                </a>
                <button onclick="alert('Eliminar')">Eliminar</button>
                <button onclick="agregarCodigo(@p.Id)">Agregar</button>
            </div>
        </div>
    }

</div>

<script>
function filtrar(tipo) {
    let productos = document.querySelectorAll(".producto");

    productos.forEach(p => {
        if (tipo === "Todos" || p.dataset.tipo === tipo) {
            p.style.display = "block";
        } else {
            p.style.display = "none";
        }
    });
}
</script>

<!-- CAMARA -->
<div class="camara">
    <a href="/Home/EscaneoCodigo">
        <img src="~/images/camara2.png" />
    </a> 
</div>

<script>
function agregarCodigo(idProducto) {

    fetch('/Home/GenerarCodigoProducto?id=' + idProducto)
    .then(res => res.json())
    .then(data => {

        if (data.ok) {
            alert("Código generado: " + data.codigo + " ✅");
        } else {
            alert("Error al generar código ❌");
        }

    });
}
</script>

<!-- LOGOS -->
<div class="logo-centro">
    <img src="~/images/logoCDNsis.png" />
</div>

<div class="logo-derecha">
    <img src="~/images/logoMM.png" />
</div>