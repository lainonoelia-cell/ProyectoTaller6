@model List<ProyectoTaller6.Models.Categoria>

@{
    ViewData["Title"] = "Inventario1";
    var error = Context.Request.Query["error"];
}

<!-- 🔴 MODAL ERROR (VA ARRIBA DE TODO) -->
@if (!string.IsNullOrEmpty(error))
{
    <div id="modalError" class="modal error">
        <div class="modal-content">
            <h2>❌ Producto no encontrado</h2>
            <p>El código escaneado no existe o no está registrado</p>
        </div>
    </div>
}
@{
    ViewData["Title"] = "Inventario1";
}

<link rel="stylesheet" href="~/css/inventario1.css" />

<h1 class="titulo">GESTIÓN INVENTARIO 1- Admin</h1>

<!-- 🔥 CREAR CATEGORIA -->
<div style="margin-bottom:20px;">
    <input type="text" id="nombreCategoria" placeholder="Nombre categoría" />
    <input type="text" id="imagenCategoria" placeholder="Imagen (ej: remera.png)" />

    <button class="btn-crear-categoria" onclick="crearCategoria()">
        Crear categoría
    </button>
</div>

<!-- 🔥 CATEGORIAS DINAMICAS -->
<div class="contenedor">

@foreach (var c in Model)
{
    <div class="producto">
        <a href="/Home/Categoria?tipo=@c.Nombre">
            <img src="~/images/@c.Imagen" />
        </a>
    </div>
}

</div>

<!-- LOGOS -->
<div class="logo-centro">
    <img src="~/images/logoCDNsis.png" />
</div>

<div class="logo-derecha">
    <img src="~/images/logoMM.png" />
</div>

<a href="/Home/Bienvenida" class="btn-volver">⬅</a>

<!-- 🔥 JS -->
<script>
function crearCategoria() {

    let nombre = document.getElementById("nombreCategoria").value;
    let imagen = document.getElementById("imagenCategoria").value;

    fetch('/Home/CrearCategoria', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
            Nombre: nombre,
            Imagen: imagen
        })
    })
    .then(res => res.json())
    .then(data => {
        if (data.ok) {
            alert("Categoría creada ✅");
            location.reload();
        } else {
            alert("Error ❌");
        }
    });
}

function cerrarModal() {
    document.getElementById("modalError").style.display = "none";
    window.location.href = "/Home/Inventario1";
}


document.addEventListener("DOMContentLoaded", function () {

    const errorModal = document.getElementById("modalError");

    if (errorModal) {

        if (navigator.vibrate) {
            navigator.vibrate([200, 100, 200]);
        }

        new Audio("/sounds/error.mp3").play();

        setTimeout(() => {
            window.location.href = "/Home/Inventario1";
        }, 3000);
    }
});
</script>