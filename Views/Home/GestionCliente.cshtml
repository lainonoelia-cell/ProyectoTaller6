@{
    var usuario = TempData["UsuarioRed"];
    var red = TempData["RedSocial"];
}


<!DOCTYPE html>

<html lang="es">

    
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MM Indumentaria</title>
    <link rel="stylesheet" href="~/css/gestionCliente.css" />
</head>
<body>
    @if(usuario != null)
{
    <h2>Bienvenida @usuario</h2>
    <p>Ingresaste con @red</p>
}
    <div class="container">
        <!-- LOGO CENTRADO -->
        <div class="logo-centrado">
            <img src="~/images/logoMM.png" alt="Logo" onerror="this.style.display='none'">
        </div>


<!-- BOTÓN VOLVER -->
<div class="volver-container">
    <button class="btn-volver" onclick="volverBienvenida()">← 
    </button>
</div>

        <!-- MENÚ CENTRADO -->
       <div class="menu-centrado">
    <a href="@Url.Action("GestionCliente", "Home")">
    Productos
</a>

    <a href="#" onclick="verContactos()">
        Contactos
    </a>

    <a href="#" onclick="verGuiaTalles()">
        Guía de Talles
    </a>

    <a href="#" onclick="verDescuentos()">
        Descuentos
    </a>
</div>

        <!-- CONTENIDO PRINCIPAL -->
        <div class="contenido">
            <!-- CATEGORÍAS -->
            <div class="categorias">
                <div class="categorias-grid">
                    <!-- Remeras -->
                    <div class="card-categoria" onclick="irACatalogo('Remeras')">
                        <img src="~/images/remeragris.jpeg" alt="Remeras" onerror="this.src='https://via.placeholder.com/120x85?text=Remeras'">
                        <h3>Remeras</h3>
                        <button class="btn-seleccionar" onclick="event.stopPropagation(); irACatalogo('Remeras')">Seleccionar</button>
                    </div>

                    <!-- Pantalones -->
                    <div class="card-categoria" onclick="irACatalogo('Pantalones')">
                        <img src="~/images/pantalonBaggy.png" alt="Pantalones" onerror="this.src='https://via.placeholder.com/120x85?text=Pantalones'">
                        <h3>Pantalones</h3>
                        <button class="btn-seleccionar" onclick="event.stopPropagation(); irACatalogo('Pantalones')">Seleccionar</button>
                    </div>

                    <!-- Abrigos -->
                    <div class="card-categoria" onclick="irACatalogo('Abrigos')">
                        <img src="~/images/campera1.jpeg" alt="Abrigos" onerror="this.src='https://via.placeholder.com/120x85?text=Abrigos'">
                        <h3>Abrigos</h3>
                        <button class="btn-seleccionar" onclick="event.stopPropagation(); irACatalogo('Abrigos')">Seleccionar</button>
                    </div>

                    <!-- Cortos -->
                    <div class="card-categoria" onclick="irACatalogo('Cortos')">
                        <img src="~/images/bermudasCamufladas.png" alt="Cortos" onerror="this.src='https://via.placeholder.com/120x85?text=Cortos'">
                        <h3>Cortos</h3>
                        <button class="btn-seleccionar" onclick="event.stopPropagation(); irACatalogo('Cortos')">Seleccionar</button>
                    </div>
                </div>

                <!-- VER MÁS -->
                <div class="ver-mas">
                    <button onclick="mostrarMasCategorias()">Ver más...</button>
                </div>

                <!-- CATEGORÍAS EXTRA (ocultas) -->
                <div id="categoriasExtra" class="categorias-extra">
                    <div class="categorias-grid">
                        <div class="card-categoria" onclick="irACatalogo('Accesorios')">
                            <img src="~/images/gorra.png" alt="Accesorios" onerror="this.src='https://via.placeholder.com/120x85?text=Accesorios'">
                            <h3>Accesorios</h3>
                            <button class="btn-seleccionar" onclick="event.stopPropagation(); irACatalogo('Accesorios')">Seleccionar</button>
                        </div>
                        <div class="card-categoria" onclick="irACatalogo('Interiores')">
                            <img src="~/images/mediasDeportivasHombre.png" alt="Interiores" onerror="this.src='https://via.placeholder.com/120x85?text=Interiores'">
                            <h3>Interiores</h3>
                            <button class="btn-seleccionar" onclick="event.stopPropagation(); irACatalogo('Interiores')">Seleccionar</button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- PANEL DERECHO - SOLO BUSCADOR -->
            <div class="panel-derecho">
                <input type="text" class="buscador" placeholder="Buscar" id="buscador" onkeyup="buscarCategorias()">
            </div>
        </div>
    </div>

    <!-- MODAL GUÍA DE TALLES -->
    <div id="modalTalles" class="modal">
        <div class="modal-content">
            <span class="close-modal" onclick="cerrarModal()">&times;</span>
            <h3>Guía de Talles</h3>
            <table>
                <thead>
                    <tr><th>Talle</th><th>Pecho</th><th>Cintura</th><th>Cadera</th></tr>
                </thead>
                <tbody>
                    <tr>
    <td>S</td>
    <td>88-92</td>
    <td>70-74</td>
    <td>94-98</td>
</tr>

<tr>
    <td>M</td>
    <td>92-96</td>
    <td>74-78</td>
    <td>98-102</td>
</tr>

<tr>
    <td>L</td>
    <td>96-100</td>
    <td>78-82</td>
    <td>102-106</td>
</tr>

<tr>
    <td>XL</td>
    <td>100-104</td>
    <td>82-86</td>
    <td>106-110</td>
</tr>
                </tbody>
            </table>
        </div>
    </div>

    <script>

    function mostrarMasCategorias() {
        document.getElementById('categoriasExtra').classList.toggle('mostrar');
    }

    // ✅ FUNCIÓN CORREGIDA - Redirige a ProductoDetalle
    function irACatalogo(categoria) {
        localStorage.setItem('categoriaSeleccionada', categoria);
        window.location.href = '@Url.Action("ProductoDetalle", "Home")';
    }

   function buscarCategorias() {

    var busqueda = document.getElementById('buscador').value.toLowerCase();

    var cards = document.querySelectorAll('.card-categoria');

    var categoriasExtra = document.getElementById('categoriasExtra');

    // Si el usuario escribe algo, mostrar categorías extra
    if (busqueda !== '') {
        categoriasExtra.classList.add('mostrar');
    } else {
        categoriasExtra.classList.remove('mostrar');
    }

    cards.forEach(function(card) {

        var titulo = card.querySelector('h3').innerText.toLowerCase();

        if (titulo.includes(busqueda)) {
            card.style.display = '';
        } else {
            card.style.display = 'none';
        }

    });
}

    function verGuiaTalles() {
        document.getElementById('modalTalles').style.display = 'block';
    }

    function cerrarModal() {
        document.getElementById('modalTalles').style.display = 'none';
    }

    function abrirRedSocial(red) {
        var urls = {
            'instagram': 'https://www.instagram.com/',
            'facebook': 'https://www.facebook.com/',
            'whatsapp': 'https://wa.me/'
        };
        if (urls[red]) window.open(urls[red], '_blank');
    }

    window.onclick = function(e) {
        var modal = document.getElementById('modalTalles');
        if (e.target === modal) modal.style.display = 'none';
    }

    function verContactos() {
    alert(
        "MM&M Indumentaria\n\n" +
        "Instagram: @@mmm_indumentaria\n" +
        "WhatsApp: 11-5555-5555"
    );
}

function verDescuentos() {

    alert(
        "Descuentos disponibles:\n\n" +
        "• 20% OFF efectivo\n" +
        "• 3 cuotas sin interés\n" +
        "• 2x1 en accesorios"
    );
}

function volverBienvenida() {
    window.location.href = '@Url.Action("Bienvenida", "Home")';
}

    </script>
</body>
</html>
