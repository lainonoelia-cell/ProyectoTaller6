
@model ProyectoTaller6.Models.Producto
<link rel="stylesheet" href="~/css/inventario2.css" asp-append-version="true" />

@if (TempData["Success"] != null)
{
    <div id="modalSuccess" class="modal success">
        <div class="modal-content">
            <h2>✅ Producto encontrado</h2>
            <p>@TempData["Success"]</p>
        </div>
    </div>
}

@if (Model == null)
{
    <h2 style="color:red; text-align:center;">
        Producto no encontrado
    </h2>

    <div style="text-align:center;">
        <a href="/Home/Inventario1">⬅ Volver</a>
    </div>

    return;

    
}
@{
    ViewData["Title"] = "Inventario2";
}



<h1 class="titulo">GESTIÓN INVENTARIO 2</h1>

<div class="contenedor-inv2">

    <!-- IMAGEN PRODUCTO -->
    <div class="producto-img">
        <img src="~/images/@Model.Imagen" />
    </div>

    <!-- PROMO -->
    <div class="promo">
        <h2>Promo</h2>

        <div class="dropdown">
    <select id="descuento">
        <option value="">Seleccionar descuento</option>
         <option value="0">0%</option>
        <option value="5">5%</option>
        <option value="10">10%</option>
        <option value="15">15%</option>
        <option value="20">20%</option>
        <option value="25">25%</option>
        <option value="30">30%</option>
        <option value="40">40%</option>
        <option value="45">45%</option>
        <option value="50">50%</option>
        <option value="60">60%</option>
        <option value="70">70%</option>
        <option value="80">80%</option>
        <option value="90">90%</option>
        <option value="100">100%</option>
    </select>
</div>
    </div>

    


<script>
    const select = document.getElementById("descuento");

let precioBase = @(Model?.Precio ?? 0);

select.addEventListener("change", function () {

    let descuento = parseFloat(this.value);

    if (!isNaN(descuento)) {

        let precioFinal = precioBase - (precioBase * descuento / 100);

        document.getElementById("descuento-texto").innerText =
            "Descuento: " + descuento + "%";

        let precioFinalElemento =
            document.getElementById("precio-final");

        precioFinalElemento.innerText =
            "Precio final: $" + precioFinal;

        // COLORES DINÁMICOS

        if (descuento == 0) {

            precioFinalElemento.style.color = "#111827";

        }
        else if (descuento <= 20) {

            precioFinalElemento.style.color = "#16a34a";

        }
        else if (descuento <= 50) {

            precioFinalElemento.style.color = "#d97706";

        }
        else {

            precioFinalElemento.style.color = "#dc2626";

        }
    }
});
</script>


    <!-- INFO FINAL 1 -->
  <div class="info-producto">

<p class="codigo-producto">
     <strong>Código:</strong> @Model.Codigo
     </p>

    <p class="nombre-producto">@Model.Nombre</p>


@if (Model.Stock == 0)
{
    <p class="stock-agotado">
        <strong>Stock:</strong> @Model.Stock unidades
    </p>
}
else if (Model.Stock <= 5)
{
    <p class="stock-bajo">
        <strong>Stock:</strong> @Model.Stock unidades
    </p>
}
else
{
    <p class="stock-ok">
        <strong>Stock:</strong> @Model.Stock unidades
    </p>
}

    <hr>

    <p id="precio">
        <strong>Precio:</strong> $@Model.Precio
    </p>

    <p id="descuento-texto">
        <strong>Descuento:</strong>
    </p>

    <p id="precio-final" class="precio-final">
        Precio final:
    </p>

</div>

</div> <!-- cierre de contenedor-inv2 -->

<!-- LOGO CENTRO ABAJO -->
<div class="logo-centro">
    <img src="~/images/logoCDNsis.png" />
</div>

<!-- LOGO DERECHA -->
<div class="logo-derecha">
    <img src="~/images/logoMM.png" />
</div>

<!-- VOLVER -->
<a href="/Home/Inventario1" class="btn-volver">⬅</a>