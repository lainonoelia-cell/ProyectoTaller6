
@model ProyectoTaller6.Models.Producto
@{
    ViewData["Title"] = "Inventario2";
}

<link rel="stylesheet" href="~/css/inventario2.css" />

<h1 class="titulo">GESTIÓN INVENTARIO 2</h1>

<div class="contenedor-inv2">

    <!-- IMAGEN PRODUCTO -->
    <div class="producto-img">
        <img src="~/images/@Model.Imagen" />
    </div>

    <!-- PROMO -->
    <div class="promo">
        <h2>Promo</h2>

        <div class="dropdown">
    <select id="descuento">
        <option value="">Seleccionar descuento</option>
        <option value="5">5%</option>
        <option value="10">10%</option>
        <option value="15">15%</option>
        <option value="20">20%</option>
        <option value="25">25%</option>
        <option value="30">30%</option>
        <option value="40">40%</option>
        <option value="45">45%</option>
        <option value="50">50%</option>
        <option value="60">60%</option>
        <option value="70">70%</option>
        <option value="80">80%</option>
        <option value="90">90%</option>
        <option value="100">100%</option>
    </select>
</div>

        <button class="btn-aplicar">Aplicar</button>
    </div>

    


<script>
    const select = document.getElementById("descuento");

    let precioBase = @Model.Precio;

    select.addEventListener("change", function () {
        let descuento = parseFloat(this.value);

        if (!isNaN(descuento)) {
            let precioFinal = precioBase - (precioBase * descuento / 100);

            document.getElementById("descuento-texto").innerText = "Descuento: " + descuento + "%";
            document.getElementById("precio-final").innerText = "Precio final: $" + precioFinal;
        }
    });
</script>


    <!-- INFO FINAL 1 -->
    <div class="resultado1">
        <div class="resultado1">
    <p>Código: @Model.Codigo</p>
    <p>Nombre: @Model.Nombre</p>
    <p>Stock: @Model.Stock unidades</p>
</div>
    </div>

    <!-- INFO FINAL 2 -->
    <div class="resultado2">
   <p id="precio">Precio: $@Model.Precio</p>
    <p id="descuento-texto">Descuento: </p>
    <p id="precio-final" class="precio-final">Precio final: </p>
</div>

</div>

<!-- LOGO CENTRO ABAJO -->
<div class="logo-centro">
    <img src="~/images/logoCDNsis.png" />
</div>

<!-- LOGO DERECHA -->
<div class="logo-derecha">
    <img src="~/images/logoMM.png" />
</div>

<!-- VOLVER -->
<a href="/Home/Inventario1" class="btn-volver">⬅</a>