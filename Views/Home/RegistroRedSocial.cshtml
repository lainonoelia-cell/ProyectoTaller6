@{
    ViewData["Title"] = "Registro Red Social";
    string red = ViewBag.Red ?? "Red Social";
}

<style>
    body{
        background-color:#d9c09c;
    }

    .registro-box{
        width:400px;
        margin:100px auto;
        padding:35px;
        background-color:#f3e6cf;
        border-radius:25px;
        text-align:center;
        box-shadow:0 4px 15px rgba(0,0,0,0.3);
    }

    .registro-box h1{
        font-size:32px;
        margin-bottom:15px;
    }

    .registro-box input{
        width:90%;
        padding:12px;
        margin-top:20px;
        border-radius:15px;
        border:1px solid #777;
        font-size:16px;
    }

    .registro-box button{
        margin-top:25px;
        padding:12px 35px;
        border:none;
        border-radius:20px;
        background-color:#8a7a2f;
        color:white;
        font-weight:bold;
        font-size:17px;
        cursor:pointer;
    }
</style>

<div class="registro-box">
    <h1>Ingresar con @red</h1>

    <p>Escribí tu nombre de usuario para continuar</p>

    <form method="post" action="/Home/RegistroRedSocial">
        <input type="hidden" name="red" value="@red" />

        <input type="text" name="usuarioRed" placeholder="Tu usuario de @red" required />

        <br />

        <button type="submit">Continuar</button>
    </form>
</div>